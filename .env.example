# API
APP_NAME="Queue System API"
HOST=0.0.0.0
PORT=8000
WORKER_CONCURRENCY=3
JOB_PROCESSING_MIN=1.0
JOB_PROCESSING_MAX=5.0
JOB_FAILURE_RATE=0.1

# PostgreSQL
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=queue_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_EMAIL=your_email@example.com
PGADMIN_PASSWORD=your_pgadmin_password

# JWT — gere uma chave forte: openssl rand -hex 32
JWT_SECRET_KEY=your_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Admin padrão (usado apenas no primeiro startup)
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
